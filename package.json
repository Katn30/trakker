{
  "name": "@katn30/trakr",
  "version": "2.0.0",
  "description": "TypeScript state-management library implementing the Unit of Work pattern, with object tracking for undo/redo and validation support.",
  "type": "module",
  "main": "./dist/prod/index.cjs",
  "module": "./dist/prod/index.js",
  "types": "./dist/dev/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/dev/index.d.ts",
      "development": {
        "import": "./dist/dev/index.js",
        "require": "./dist/dev/index.cjs"
      },
      "default": {
        "import": "./dist/prod/index.js",
        "require": "./dist/prod/index.cjs"
      }
    }
  },
  "author": "Katn30",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Katn30/trackt"
  },
  "keywords": [
    "trakr",
    "typescript",
    "undo-redo",
    "state-management",
    "unit-of-work",
    "object-tracking",
    "commit"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}